# =============================================================================
# ENVIRONMENT VARIABLES — VideoSphere
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git — it is already in .gitignore
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All other variables are server-side only.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Base URL of your app (no trailing slash). Set per environment:
#   Dev:  http://localhost:3000   (or your local URL)
#   Prod: https://yourdomain.com
# For Appwrite SSR: session cookie is httpOnly, sameSite=strict; secure is true only
# in production (NODE_ENV=production) so localhost works in dev. The browser only talks
# to this app origin (e.g. /api/auth/session); Appwrite itself may be on a different
# origin, configured via NEXT_PUBLIC_APPWRITE_ENDPOINT.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=VideoSphere

# --------- OAuth Provider Credentials --------
# These are for manual OAuth implementation (handling the OAuth flow yourself).
# Get these from your OAuth provider (Google Cloud Console, GitHub, etc.)
# NEVER commit actual credentials to git — this file is an example only.
GOOGLE_AUTH_CLIENT_ID=your_google_client_id_here
GOOGLE_AUTH_CLIENT_SECRET=your_google_client_secret_here
# --------- End OAuth --------

# -----------------------------------------------------------------------------
# Appwrite (BaaS — auth + database)
# -----------------------------------------------------------------------------
# Endpoint for your Appwrite instance. Local dev: use the URL from your
# local Appwrite install (e.g. http://localhost/v1 or the port you chose).
NEXT_PUBLIC_APPWRITE_ENDPOINT=http://localhost/v1
# Project ID from the Appwrite Console (create a project first).
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id_here
# API key with scopes: Database, Users, and Sessions (sessions.write) for SSR auth.
# Create in Appwrite Console → Project → API Keys. Never expose in client code.
APPWRITE_API_KEY=your_api_key_here
# 32-byte key (base64) for encrypting OAuth tokens at rest (PRD NF-05). Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APPWRITE_TOKEN_ENCRYPTION_KEY=your_base64_32_byte_key_here

# -----------------------------------------------------------------------------
# Cloudflare R2 (video upload staging storage)
# -----------------------------------------------------------------------------
# Presigned URLs expire in 15 minutes (NF-08). Get R2 API credentials from:
# Cloudflare Dashboard → R2 → API Tokens → Create API Token (s3.read, s3.write)
# Account ID: shown in Cloudflare dashboard URL or R2 overview
R2_ACCOUNT_ID=your_account_id_here
R2_ACCESS_KEY_ID=your_r2_access_key_here
R2_SECRET_ACCESS_KEY=your_r2_secret_key_here
# Bucket name for temporary video uploads (created in R2 console)
R2_BUCKET_NAME=videosphere-uploads
# Optional: public CDN URL if using Cloudflare domain or custom domain for video delivery
# NEXT_PUBLIC_R2_PUBLIC_URL=https://videos.yourdomain.com

# -----------------------------------------------------------------------------
# Stripe (one-time payments — supporter tier)
# -----------------------------------------------------------------------------
# Use test keys (pk_test_..., sk_test_...) during development.
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# Webhook signing secret (starts with whsec_). From Stripe Dashboard → Webhooks.
# Required to verify checkout.session.completed and set supporter status.
# Left blank for not (not until we have a domain)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# -----------------------------------------------------------------------------
# OpenRouter (AI — e.g. title/description/tags for drafts)
# -----------------------------------------------------------------------------
# Get an API key at https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-your_key_here
# Model for free-tier users. Check https://openrouter.ai/models for current free models.
OPENROUTER_FREE_MODEL=meta-llama/llama-3.1-8b-instruct:free
# Model for supporter-tier users (higher quality).
OPENROUTER_PREMIUM_MODEL=openai/gpt-4o

# -----------------------------------------------------------------------------
# Figma (For dev use of design MCP)
# -----------------------------------------------------------------------------
# Get an API key at https://www.figma.com/
FIGMA_API_TOKEN=your-key-here

# -----------------------------------------------------------------------------
# Future / optional (plan for these; implement later)
# -----------------------------------------------------------------------------
# Cloudflare R2 (temporary video storage)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# This is only relevant if we enable public access on our bucket, which would let anyone access files via a public URL (like a CDN)
# NEXT_PUBLIC_R2_PUBLIC_URL=
# This is for Cloudflare's own API if we ever manage R2 programmatically via their API rather than S3
# R2_TOKEN_VALUE=

# YouTube / Vimeo / Google Drive APIs (distribution)
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# VIMEO_CLIENT_ID=
# VIMEO_CLIENT_SECRET=
# GOOGLE_DRIVE_CLIENT_ID=
# GOOGLE_DRIVE_CLIENT_SECRET=
