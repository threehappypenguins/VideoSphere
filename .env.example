# =============================================================================
# ENVIRONMENT VARIABLES — VideoSphere
# =============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git — it is already in .gitignore
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All other variables are server-side only.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=VideoSphere

# -----------------------------------------------------------------------------
# Credentials
# -----------------------------------------------------------------------------
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Appwrite (BaaS — auth + database)
# -----------------------------------------------------------------------------
# Endpoint for your Appwrite instance. Local dev: use the URL from your
# local Appwrite install (e.g. http://localhost/v1 or the port you chose).
NEXT_PUBLIC_APPWRITE_ENDPOINT=http://localhost/v1
# Project ID from the Appwrite Console (create a project first).
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id_here
# API key with scopes needed for server-side access (e.g. Database, Users).
# Create in Appwrite Console → Project → API Keys. Never expose in client code.
APPWRITE_API_KEY=your_api_key_here

# -----------------------------------------------------------------------------
# Stripe (one-time payments — supporter tier)
# -----------------------------------------------------------------------------
# Use test keys (pk_test_..., sk_test_...) during development.
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# Webhook signing secret (starts with whsec_). From Stripe Dashboard → Webhooks.
# Required to verify checkout.session.completed and set supporter status.
# Left blank for not (not until we have a domain)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# -----------------------------------------------------------------------------
# OpenRouter (AI — e.g. title/description/tags for drafts)
# -----------------------------------------------------------------------------
# Get an API key at https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# -----------------------------------------------------------------------------
# Future / optional (plan for these; implement later)
# -----------------------------------------------------------------------------
# Cloudflare R2 (temporary video storage)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# This is only relevant if we enable public access on our bucket, which would let anyone access files via a public URL (like a CDN)
# NEXT_PUBLIC_R2_PUBLIC_URL=
# This is for Cloudflare's own API if we ever manage R2 programmatically via their API rather than S3
# R2_TOKEN_VALUE=

# YouTube / Vimeo / Google Drive APIs (distribution)
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# VIMEO_CLIENT_ID=
# VIMEO_CLIENT_SECRET=
# GOOGLE_DRIVE_CLIENT_ID=
# GOOGLE_DRIVE_CLIENT_SECRET=
