{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["components", "hooks", "lib", "types", "app"],
  "entryPointStrategy": "expand",
  "tsconfig": "./tsconfig.json",
  "out": "docs/public/typedoc",
  "exclude": [
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.d.ts",
    "**/node_modules/**",
    "**/.next/**"
  ],
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeInternal": true,
  "readme": "none",
  "hideGenerator": true,
  "cleanOutputDir": true,
  "sort": ["source-order"],
  "validation": {
    "notExported": false
  }
}
